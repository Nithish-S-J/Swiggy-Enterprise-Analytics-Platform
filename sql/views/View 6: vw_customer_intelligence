CREATE OR ALTER VIEW dbo.vw_customer_intelligence
AS

SELECT

    dc.customer_id,

    dc.customer_segment,

    dc.total_orders,

    dc.avg_order_value,

    dc.avg_service_rating,

    COUNT(fo.order_id) AS orders_placed,

    SUM(fo.order_value_inr) AS total_customer_revenue,

    ROUND(AVG(fo.order_value_inr), 2 ) AS customer_avg_order_value,

    ROUND( AVG(fo.service_rating), 2 ) AS customer_avg_rating,

    SUM(
        CASE
            WHEN fo.refund_requested = 'Yes'
            THEN 1
            ELSE 0
        END) AS refund_orders,

    ROUND(
        SUM(
            CASE
                WHEN fo.refund_requested = 'Yes'
                THEN 1
                ELSE 0
            END ) * 100.0 / NULLIF(COUNT(fo.order_id),0), 2 ) AS refund_rate_pct,

    SUM(
        CASE
            WHEN fo.high_value_order_flag = 'High'
            THEN 1
            ELSE 0
        END ) AS high_value_orders,

    DENSE_RANK() OVER ( ORDER BY SUM(fo.order_value_inr) DESC ) AS revenue_rank

FROM dbo.dim_customers dc

INNER JOIN dbo.fact_orders fo
    ON dc.customer_id = fo.customer_id

GROUP BY

    dc.customer_id,
    dc.customer_segment,
    dc.total_orders,
    dc.avg_order_value,
    dc.avg_service_rating;
GO
