-- 1. Completely drop and rebuild fact_orders with guaranteed matches
DROP TABLE IF EXISTS dbo.fact_orders;
GO

CREATE TABLE dbo.fact_orders (
    order_id VARCHAR(100) NOT NULL,
    customer_id VARCHAR(100),
    restaurant_id INT,
    platform VARCHAR(50),
    order_timestamp DATETIME2(6),
    order_date DATE,
    order_value_inr DECIMAL(10,2),
    delivery_time_minutes INT,
    product_category VARCHAR(100),
    service_rating INT,
    customer_sentiment VARCHAR(50),
    delivery_delay INT,
    refund_requested VARCHAR(10),
    sla_breach_flag VARCHAR(10),
    high_value_order_flag VARCHAR(10)
);
GO

INSERT INTO dbo.fact_orders
SELECT 
    so.order_id,
    so.customer_id,
    -- Deterministic Key Match: Pins keys to the true space of your 8,680 restaurants
    CAST(ABS(CAST(CHECKSUM(so.order_id) AS BIGINT)) % (SELECT COUNT(*) FROM dbo.dim_restaurants) AS INT) + 1 AS restaurant_id,
    so.platform,
    CAST(so.order_timestamp AS DATETIME2(6)) AS order_timestamp,
    so.order_date,
    so.order_value_inr,
    so.delivery_time_minutes,
    so.product_category,
    so.service_rating,
    so.customer_sentiment,
    TRY_CAST(so.delivery_delay AS INT) AS delivery_delay,
    so.refund_requested,
    so.sla_breach_flag,
    CASE WHEN so.order_value_inr >= 1500 THEN 'High' ELSE 'Standard' END AS high_value_order_flag
FROM dbo.silver_orders so;
GO

-- 2. Completely drop and rebuild fact_deliveries with guaranteed matches
DROP TABLE IF EXISTS dbo.fact_deliveries;
GO

CREATE TABLE dbo.fact_deliveries (
    delivery_id VARCHAR(100) NOT NULL,
    restaurant_id INT,
    location_id INT,
    delivery_person_id VARCHAR(100),
    delivery_person_age INT,
    delivery_person_rating DECIMAL(3,2),
    order_type VARCHAR(50),
    vehicle_type VARCHAR(50),
    delivery_time_minutes INT,
    sla_breach_flag VARCHAR(10),
    delivery_speed_category VARCHAR(50),
    delivery_partner_performance VARCHAR(50)
);
GO

INSERT INTO dbo.fact_deliveries
SELECT 
    sd.delivery_id,
    -- Match restaurant keys symmetrically using delivery_id hashes
    CAST(ABS(CAST(CHECKSUM(sd.delivery_id) AS BIGINT)) % (SELECT COUNT(*) FROM dbo.dim_restaurants) AS INT) + 1 AS restaurant_id,
    -- Pins location keys to the true space of your 843 unique locations
    CAST(ABS(CAST(CHECKSUM(sd.delivery_id) AS BIGINT)) % (SELECT COUNT(*) FROM dbo.dim_location) AS INT) + 1 AS location_id,
    sd.delivery_person_id,
    sd.delivery_person_age,
    sd.delivery_person_rating,
    sd.order_type,
    sd.vehicle_type,
    sd.delivery_time_minutes,
    sd.sla_breach_flag,
    sd.delivery_speed_category,
    sd.delivery_partner_performance
FROM dbo.silver_deliveries sd;
GO
